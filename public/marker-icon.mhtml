import { useEffect, useState } from "react";
import { MapContainer, TileLayer, Marker, Popup } from "react-leaflet";
import "leaflet/dist/leaflet.css";

function App() {
  const [stations, setStations] =3D useState([]);
  const [filterAC, setFilterAC] =3D useState(true);
  const [filterDC, setFilterDC] =3D useState(true);

  useEffect(() =3D&gt; {
    fetch("/mock-stations.json")
      .then((res) =3D&gt; res.json())
      .then((data) =3D&gt; setStations(data.stations));
  }, []);

  const filteredStations =3D stations.filter((s) =3D&gt; {
    if (!filterAC &amp;&amp; s.type =3D=3D=3D "AC") return false;
    if (!filterDC &amp;&amp; s.type =3D=3D=3D "DC") return false;
    return true;
  });

  return (
    &lt;div className=3D"grid grid-cols-1 md:grid-cols-3 h-screen"&gt;
      &lt;div className=3D"col-span-2"&gt;
        &lt;MapContainer center=3D{[59.3293, 18.0686]} zoom=3D{6} className=
=3D"h-full w-full"&gt;
          &lt;TileLayer
            attribution=3D'&amp;copy; OpenStreetMap'
            url=3D"https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png"
          /&gt;
          {filteredStations.map((station) =3D&gt; (
            &lt;Marker key=3D{station.id} position=3D{[station.lat, station=
.lng]}&gt;
              &lt;Popup&gt;
                &lt;strong&gt;{station.name}&lt;/strong&gt;&lt;br /&gt;
                Operat=C3=B6r: {station.operator}&lt;br /&gt;
                Pris: {station.price ?? "Ok=C3=A4nt"} kr/kWh&lt;br /&gt;
                Typ: {station.type}&lt;br /&gt;
                Effekt: {station.power} kW
              &lt;/Popup&gt;
            &lt;/Marker&gt;
          ))}
        &lt;/MapContainer&gt;
      &lt;/div&gt;
      &lt;div className=3D"p-4 overflow-y-auto"&gt;
        &lt;h2 className=3D"text-xl font-bold mb-4"&gt;Laddstationer&lt;/h2=
&gt;
        &lt;div className=3D"mb-4"&gt;
          &lt;label className=3D"flex items-center space-x-2"&gt;
            &lt;input type=3D"checkbox" checked=3D{filterAC} onChange=3D{()=
 =3D&gt; setFilterAC(!filterAC)} /&gt;
            &lt;span&gt;Visa AC&lt;/span&gt;
          &lt;/label&gt;
          &lt;label className=3D"flex items-center space-x-2"&gt;
            &lt;input type=3D"checkbox" checked=3D{filterDC} onChange=3D{()=
 =3D&gt; setFilterDC(!filterDC)} /&gt;
            &lt;span&gt;Visa DC&lt;/span&gt;
          &lt;/label&gt;
        &lt;/div&gt;
        {filteredStations.map((station) =3D&gt; (
          &lt;div key=3D{station.id} className=3D"border p-2 mb-2 rounded"&=
gt;
            &lt;p className=3D"font-semibold"&gt;{station.name}&lt;/p&gt;
            &lt;p&gt;Operat=C3=B6r: {station.operator}&lt;/p&gt;
            &lt;p&gt;Pris: {station.price ?? "Ok=C3=A4nt"} kr/kWh&lt;/p&gt;
            &lt;p&gt;Typ: {station.type}&lt;/p&gt;
            &lt;p&gt;Effekt: {station.power} kW&lt;/p&gt;
          &lt;/div&gt;
        ))}
      &lt;/div&gt;
    &lt;/div&gt;
  );
}

