ne" xmlns="http://www.w3.org/2000/svg" class="icon-md-heavy"><path fill-rule="evenodd" clip-rule="evenodd" d="M11.2929 3.29289C11.6834 2.90237 12.3166 2.90237 12.7071 3.29289L16.7071 7.29289C17.0976 7.68342 17.0976 8.31658 16.7071 8.70711C16.3166 9.09763 15.6834 9.09763 15.2929 8.70711L13 6.41421V15C13 15.5523 12.5523 16 12 16C11.4477 16 11 15.5523 11 15V6.41421L8.70711 8.70711C8.31658 9.09763 7.68342 9.09763 7.29289 8.70711C6.90237 8.31658 6.90237 7.68342 7.29289 7.29289L11.2929 3.29289ZM4 14C4.55228 14 5 14.4477 5 15V18C5 18.5523 5.44772 19 6 19H18C18.5523 19 19 18.5523 19 18V15C19 14.4477 19.4477 14 20 14C20.5523 14 21 14.4477 21 15V18C21 19.6569 19.6569 21 18 21H6C4.34315 21 3 19.6569 3 18V15C3 14.4477 3.44772 14 4 14Z" fill="currentColor"></path></svg></span></button></span></div></div></div></div></div></div></article><article class="text-token-text-primary w-full" dir="auto" data-testid="conversation-turn-103" data-scroll-anchor="false" style="scroll-margin-top: -1764px;"><h5 class="sr-only">Du sade:</h5><div class="text-base my-auto mx-auto py-5 [--thread-content-margin:--spacing(4)] @[37rem]:[--thread-content-margin:--spacing(6)] @[70rem]:[--thread-content-margin:--spacing(12)] px-(--thread-content-margin)"><div class="[--thread-content-max-width:32rem] @[34rem]:[--thread-content-max-width:40rem] @[64rem]:[--thread-content-max-width:48rem] mx-auto flex max-w-(--thread-content-max-width) flex-1 text-base gap-4 md:gap-5 lg:gap-6 group/turn-messages focus-visible:outline-hidden" tabindex="-1"><div class="group/conversation-turn relative flex w-full min-w-0 flex-col"><div class="relative flex-col gap-1 md:gap-3"><div class="flex max-w-full flex-col grow"><div data-message-author-role="user" data-message-id="4506536d-d6c4-40b3-aae8-83ee68e17169" dir="auto" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal [.text-message+&amp;]:mt-5"><div class="w-full"><div class="flex w-full flex-col gap-1 empty:hidden items-end rtl:items-start"><div class="relative max-w-[var(--user-chat-width,70%)] bg-token-message-surface rounded-3xl px-5 py-2.5"><div class="whitespace-pre-wrap">import React from "react";
import { useEffect, useState } from "react";
import { MapContainer, TileLayer, Marker, Popup } from "react-leaflet";
import "leaflet/dist/leaflet.css";

function App() {
  const [stations, setStations] = useState([]);
  const [filterAC, setFilterAC] = useState(true);
  const [filterDC, setFilterDC] = useState(true);

  useEffect(() =&gt; {
    fetch("/mock-stations.json")
      .then((res) =&gt; res.json())
      .then((data) =&gt; setStations(data.stations));
  }, []);

  const filteredStations = stations.filter((s) =&gt; {
    if (!filterAC &amp;&amp; s.type === "AC") return false;
    if (!filterDC &amp;&amp; s.type === "DC") return false;
    return true;
  });

  return (
    &lt;div style={{ backgroundColor: "#f2f2f2" }}&gt;
      &lt;div className="grid grid-cols-1 md:grid-cols-3 h-screen"&gt;
        &lt;div className="col-span-2"&gt;
          &lt;MapContainer center={[59.3293, 18.0686]} zoom={6} className="h-full w-full"&gt;
            &lt;TileLayer
              attribution='&amp;copy; OpenStreetMap'
              url="https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png"
            /&gt;
            {filteredStations.map((station) =&gt; (
              &lt;Marker key={station.id} position={[station.lat, station.lng]}&gt;
                &lt;Popup&gt;
                  &lt;strong&gt;{station.name}&lt;/strong&gt;&lt;br /&gt;
                  Operatör: {station.operator}&lt;br /&gt;
                  Pris: {station.price ?? "Okänt"} kr/kWh&lt;br /&gt;
                  Typ: {station.type}&lt;br /&gt;
                  Effekt: {station.power} kW
                &lt;/Popup&gt;
              &lt;/Marker&gt;
            ))}
          &lt;/MapContainer&gt;
        &lt;/div&gt;
        &lt;div className="p-4 overflow-y-auto"&gt;
          &lt;h2 className="text-xl font-bold mb-4"&gt;Laddstationer&lt;/h2&gt;
          &lt;div className="mb-4"&gt;
            &lt;label className="flex items-center space-x-2"&gt;
              &lt;input type="checkbox" checked={filterAC} onChange={() =&gt; setFilterAC(!filterAC)} /&gt;
              &lt;span&gt;Visa AC&lt;/span&gt;
            &lt;/label&gt;
            &lt;label className="flex items-center space-x-2"&gt;
              &lt;input type="checkbox" checked={filterDC} onChange={() =&gt; setFilterDC(!filterDC)} /&gt;
              &lt;span&gt;Visa DC&lt;/span&gt;
            &lt;/label&gt;
          &lt;/div&gt;
          {filteredStations.map((station) =&gt; (
            &lt;div key={station.id} className="border p-2 mb-2 rounded"&gt;
              &lt;p className="font-semibold"&gt;{station.name}&lt;/p&gt;
              &lt;p&gt;Operatör: {station.operator}&lt;/p&gt;
              &lt;p&gt;Pris: {station.price ?? "Okänt"} kr/kWh&lt;/p&gt;
              &lt;p&gt;Typ: {station.type}&lt;/p&gt;
              &lt;p&gt;Effekt: {station.power} kW&lt;/p&gt;
            &lt;/div&gt;
          ))}
        &lt;/div&gt;
      &lt;/div&gt;
    &lt;/div&gt;
  );
}

export default App;</div></div></div></div></div></div><div class="flex absolute start-0 end-0 flex justify-end"><div class="touch:-me-2 touch:-ms-3.5 -ms-2.5 -me-1 flex items-center p-1 select-none focus-within:transition-none hover:transition-none duration-300 group-hover/turn-messages:delay-300 pointer-events-none opacity-0 motion-safe:transition-opacity group-hover/turn-messages:pointer-events-auto group-hover/turn-messages:opacity-100 group-focus-within/turn-messages:pointer-events-auto group-focus-within/turn-messages:opacity-100 has-data-[state=open]:pointer-events-auto has-data-[state=open]:opacity-100"><span class="" data-state="closed"><button class="text-token-text-secondary hover:bg-token-main-surface-secondary rounded-lg" aria-label="Kopiera" data-testid="copy-turn-action-button"><span class="touch:w-[38px] flex h-[30px] w-[30px] items-center justify-center"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="icon-md-heavy"><path fill-rule="evenodd" clip-rule="evenodd" d="M7 5C7 3.34315 8.34315 2 10 2H19C20.6569 2 22 3.34315 22 5V14C22 15.6569 20.6569 17 19 17H17V19C17 20.6569 15.6569 22 14 22H5C3.34315 22 2 20.6569 2 19V10C2 8.34315 3.34315 7 5 7H7V5ZM9 7H14C15.6569 7 17 8.34315 17 10V15H19C19.5523 15 20 14.5523 20 14V5C20 4.44772 19.5523 4 19 4H10C9.44772 4 9 4.44772 9 5V7ZM5 9C4.44772 9 4 9.44772 4 10V19C4 19.5523 4.44772 20 5 20H14C14.5523 20 15 19.5523 15 19V10C15 9.44772 14.5523 9 14 9H5Z" fill="currentColor"></path></svg></span></button></span><span class="" data-state="closed"><button class="text-token-text-secondary hover:bg-token-main-surface-secondary rounded-lg" aria-label="Redigera meddelande"><span class="touch:w-[38px] flex h-[30px] w-[30px] items-center justify-center"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="icon-md-heavy"><path fill-rule="evenodd" clip-rule="evenodd" d="M13.2929 4.29291C15.0641 2.52167 17.9359 2.52167 19.7071 